# Copy this file to .env and fill in values.
# NEVER commit .env to version control — it is gitignored.

# Alerting — leave empty to run in mock/log-only mode
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scraper behaviour
SCRAPE_INTERVAL_MINUTES=15
REQUEST_TIMEOUT_SECONDS=10
USER_AGENT=SupremeScraper/1.0 (InfoSec Course Research Bot)

# Database
DATABASE_URL=sqlite+aiosqlite:///./supreme_drops.db

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
